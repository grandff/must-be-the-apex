{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "MustBeTheApex.Agent": "Debug"
    }
  },
  "Agent": {
    // ===== UDP 리스너 설정 =====
    // F1 25 게임이 보내는 UDP 포트 (게임 설정에서 변경 가능)
    "UdpPort": 20777,

    // ===== WebSocket 서버 설정 =====
    // 데이터 전송할 서버 주소 (Remix 서버)
    // 로컬: ws://localhost:3000/ws
    // 외부 IP: ws://YOUR_SERVER_IP:3000/ws
    // 심허브 포트포워딩: ws://YOUR_SIMHUB_TUNNEL_URL:PORT/ws
    "WebSocketUrl": "ws://localhost:3000/ws",

    // ===== 샘플레이트 설정 =====
    // 초당 전송 횟수 (10Hz = 100ms interval)
    "TelemetrySampleRateHz": 10,

    // ===== 파일 저장 설정 =====
    // 파일 저장을 활성화할지 여부
    "SaveToFile": true,
    // 데이터 저장 경로 (상대경로는 실행 디렉토리 기준)
    // Windows: "./telemetry_data" or "C:\\TelemetryData"
    "FileSavePath": "./telemetry_data",
    // 파일 형식: JsonLines (NDJSON), JsonPretty, Csv
    "FileFormat": "JsonLines",
    // 최대 파일 크기 (MB)
    "MaxFileSizeMb": 10,
    // 보관할 최대 파일 수
    "MaxFileCount": 10
  }
}
