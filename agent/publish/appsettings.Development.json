{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Hosting.Lifetime": "Information",
      "MustBeTheApex.Agent": "Debug"
    }
  },
  "Agent": {
    // 개발용: 로컬 Remix 서버
    "UdpPort": 20777,
    "WebSocketUrl": "ws://localhost:3000/ws",
    "TelemetrySampleRateHz": 10,
    "SaveToFile": true,
    "FileSavePath": "./telemetry_data_dev",
    "FileFormat": "JsonLines",
    "MaxFileSizeMb": 5,
    "MaxFileCount": 5
  }
}
